# ============================================================
# WebApiNibu - Environment Variables for Coolify
# ============================================================
# Copy these into Coolify > Service > Environment Variables
# ============================================================

# --- Database (PostgreSQL - already deployed) ---
DB_HOST=38.49.214.67
DB_PORT=5432
DB_NAME=WebApiNibu
DB_USER=postgres
DB_PASSWORD=YourDatabasePasswordHere

# --- JWT Authentication ---
JWT_SECRET_KEY=YourSuperSecretKeyForJWT2024!MustBeAtLeast32Characters
JWT_ISSUER=SisApi
JWT_AUDIENCE=SisApiClient

# --- Auth Microservice ---
AUTH_MICROSERVICE_URL=https://sisapi.xchar.site

# --- Project Permission Service ---
PROJECT_PERMISSION_URL=https://sisapi.xchar.site
PROJECT_PERMISSION_ENDPOINT=/api/ProjectPermission
PROJECT_PERMISSION_MODULE=2

# --- CORS (comma-separated allowed origins) ---
ALLOWED_ORIGINS=https://yourfrontend.example.com,https://anotherfrontend.example.com

# --- Domain (used by Traefik label in docker-compose) ---
DOMAIN=webapinibu.example.com

